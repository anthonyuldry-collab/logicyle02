# Logicycle – variables d'environnement (copier en .env et remplir)

# Firebase (obligatoire pour démarrer l'application)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Web Push (convocations digitales — Firebase Console → Cloud Messaging → certificats Web)
VITE_FIREBASE_VAPID_KEY=

# Stripe (facturation self-serve — Cloud Functions)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Price IDs Stripe (créer dans Dashboard Stripe → Products)
# STRIPE_PRICE_CLUB_MONTH=price_...
# STRIPE_PRICE_CLUB_YEAR=price_...
# STRIPE_PRICE_COMPETITION_MONTH=price_...
# STRIPE_PRICE_COMPETITION_YEAR=price_...
# STRIPE_PRICE_CONTINENTAL_MONTH=price_...
# STRIPE_PRICE_CONTINENTAL_YEAR=price_...
# STRIPE_PRICE_PRO_MONTH=price_...
# STRIPE_PRICE_PRO_YEAR=price_...
# STRIPE_PRICE_INDEPENDENT_RIDER_MONTH=price_...
# STRIPE_PRICE_INDEPENDENT_RIDER_YEAR=price_...
# STRIPE_PRICE_INDEPENDENT_STAFF_MONTH=price_...
# STRIPE_PRICE_INDEPENDENT_STAFF_YEAR=price_...
# STRIPE_COUPON_REFERRAL_REFEREE=coupon_...  # 10 % once, 1ère année (Dashboard Stripe)
# ALLOWED_APP_ORIGINS=https://logicyle.app,https://www.logicyle.app  # whitelist redirects Stripe

# Gemini
# Production : secret Cloud Functions (NE PAS exposer côté client)
#   firebase functions:config:set gemini.key="..."  OU  env GEMINI_API_KEY=
#   puis déployer : firebase deploy --only functions
# Développement local (dev only, fallback) :
VITE_GEMINI_API_KEY=

# Nolio (volume d'entraînement coureur — OAuth côté client)
# Créer l'app : https://www.nolio.io/api
# redirect_uri = URL de prod/dev (ex. https://app.example.com/)
VITE_NOLIO_CLIENT_ID=

# Cloud Functions (secrets serveur — firebase functions:secrets:set)
# NOLIO_CLIENT_ID=
# NOLIO_CLIENT_SECRET=
# GEMINI_API_KEY=   # lecture auto CV (extractCvProfile) + usages serveur Gemini

# --- Firebase Console ---
# 1. Project settings → Your apps → SDK setup : copier les 6 clés VITE_FIREBASE_*
# 2. Local : fichier `.env` à la racine (jamais committer) puis `npm run dev`
# 3. Prod / Netlify : committer `.env.production` (clés Firebase client uniquement)
#    OU les définir dans Site settings → Environment variables, puis Trigger deploy
#    (Vite les injecte uniquement au moment du build)
# 4. Authentication → Sign-in method → activer « Email link »
# 5. Authentication → Settings → Authorized domains : ajouter votre domaine de prod
# 6. Déployer les règles et fonctions :
#    firebase deploy --only firestore:rules,storage:rules,functions
# 7. Configurer le webhook Stripe :
#    URL : https://<region>-<project>.cloudfunctions.net/stripeWebhook
#    Événements : checkout.session.completed, customer.subscription.updated, customer.subscription.deleted

# Observabilité (optionnel — Sentry)
# VITE_SENTRY_DSN=https://...@o....ingest.sentry.io/...
# VITE_APP_VERSION=1.0.0

# GPS webhook URL explicite (sinon dérivée du projectId Firebase)
# VITE_GPS_WEBHOOK_URL=https://europe-west1-logicycle01.cloudfunctions.net/ingestVehicleGps

# --- Secrets Cloud Functions (Gen2) — NE PAS mettre dans VITE_* ---
# firebase functions:secrets:set STRIPE_SECRET_KEY
# firebase functions:secrets:set STRIPE_WEBHOOK_SECRET
# firebase functions:secrets:set NOLIO_CLIENT_ID
# firebase functions:secrets:set NOLIO_CLIENT_SECRET
# firebase functions:secrets:set GEMINI_API_KEY
# Price IDs Stripe : variables d'environnement Cloud Run (console GCP) ou:
#   gcloud run services update FUNCTION_NAME --set-env-vars STRIPE_PRICE_CLUB_MONTH=price_...
#
# Health check prod :
#   curl https://europe-west1-logicycle01.cloudfunctions.net/healthz
