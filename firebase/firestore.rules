rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function userExists() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function userDoc() {
      return userData();
    }

    function authEmail() {
      return request.auth.token.email;
    }

    /** Super Admin : email Auth (non spoofable via doc Firestore). */
    function isSuperAdmin() {
      return isSignedIn() && (
        authEmail() == 'anthony.uldry@hotmail.fr'
      );
    }

    function isTeamMember(teamId) {
      return userExists() && userData().teamId == teamId;
    }

    /** Aligné sur types.ts : UserRole.MANAGER = "Manager", TeamRole.ADMIN = "Administrateur". */
    function isTeamManager(teamId) {
      return isTeamMember(teamId) && (
        userData().userRole == 'Manager' ||
        userData().permissionRole == 'Administrateur'
      );
    }

    function subscriptionUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['subscription']);
    }

    /** Champs que l’utilisateur ne peut pas s’auto-attribuer. */
    function userSensitiveKeysUnchanged() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'teamId',
        'userRole',
        'permissionRole',
        'email',
        'subscription',
        'customPermissions',
        'isActive',
        'isIndependentProfile',
        'signupMode',
        'isSuperAdmin'
      ]);
    }

    function managerUserUpdateAllowed() {
      // Manager peut lier un membre / rôles / permissions custom ; pas l’abo ni l’email.
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'subscription',
        'email',
        'isSuperAdmin'
      ]);
    }

    /** Activation espace indépendant (depuis no_team, sans élévation de rôle). */
    function canActivateIndependent() {
      return resource.data.teamId == null
        && request.resource.data.isIndependentProfile == true
        && request.resource.data.signupMode == 'independent'
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'email',
          'userRole',
          'permissionRole',
          'customPermissions',
          'isActive'
        ]);
    }

    /** Profil indépendant déjà actif : maj profil, pas les privilèges ni l’abonnement (Stripe/webhook uniquement). */
    function independentSelfUpdateAllowed() {
      return resource.data.isIndependentProfile == true
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          'teamId',
          'userRole',
          'permissionRole',
          'email',
          'subscription',
          'customPermissions',
          'isActive',
          'isIndependentProfile',
          'signupMode'
        ]);
    }

    /** Accès partenaire actif pour teamId cible (doc id déterministe userId_teamId). */
    function hasActivePartnerAccess(teamId) {
      return exists(/databases/$(database)/documents/partnerAccesses/$(request.auth.uid + '_' + teamId))
        && get(/databases/$(database)/documents/partnerAccesses/$(request.auth.uid + '_' + teamId)).data.isActive == true
        && get(/databases/$(database)/documents/partnerAccesses/$(request.auth.uid + '_' + teamId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/partnerAccesses/$(request.auth.uid + '_' + teamId)).data.teamId == teamId;
    }

    /** Partenaire : bascule teamId uniquement vers une équipe autorisée (ou null pour sortir). */
    function partnerTeamIdSwitchAllowed() {
      return resource.data.userRole == 'Partenaire'
        && request.resource.data.userRole == 'Partenaire'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamId', 'updatedAt'])
        && (
          request.resource.data.teamId == null
          || hasActivePartnerAccess(request.resource.data.teamId)
        );
    }

    match /users/{userId} {
      allow read: if isSelf(userId)
        || (userExists()
            && resource.data.teamId != null
            && resource.data.teamId == userData().teamId)
        || (isSignedIn() && resource.data.isSearchable == true)
        || isSuperAdmin();

      // NOTE: userRole Manager autorisé à l'inscription (intention), mais permissionRole
      // élevé (Administrateur) et teamId sont attribués uniquement via Cloud Function.
      allow create: if isSelf(userId)
        && request.resource.data.email == authEmail()
        && request.resource.data.userRole in ['Coureur', 'Staff', 'Partenaire', 'Invité', 'Manager']
        && (
          !('permissionRole' in request.resource.data)
          || request.resource.data.permissionRole in ['Membre', 'Athlète', 'Editeur']
        )
        && (
          !('teamId' in request.resource.data)
          || request.resource.data.teamId == null
        )
        && (
          !('subscription' in request.resource.data)
          || request.resource.data.userRole in ['Coureur', 'Staff', 'Partenaire', 'Invité']
        );

      allow update: if isSuperAdmin()
        || (isSelf(userId) && userSensitiveKeysUnchanged())
        || (isSelf(userId) && canActivateIndependent())
        || (isSelf(userId) && independentSelfUpdateAllowed())
        || (isSelf(userId) && partnerTeamIdSwitchAllowed())
        || (userExists()
            && managerUserUpdateAllowed()
            && (
              isTeamManager(resource.data.teamId)
              || (resource.data.teamId == null
                  && request.resource.data.teamId != null
                  && isTeamManager(request.resource.data.teamId))
            ));

      allow delete: if isSelf(userId) || isSuperAdmin();
    }

    function isCoureur() {
      return userExists() && userData().userRole == 'Coureur';
    }

    function canReadTeamSubdoc(teamId, subcollection, docId) {
      return isTeamManager(teamId)
        || !isCoureur()
        || subcollection != 'riders'
        || docId == request.auth.uid
        || (resource.data.email == authEmail());
    }

    /** Collections financières / RH sensibles interdites aux coureurs. */
    function canCoureurReadCollection(subcollection) {
      return !(subcollection in [
        'performanceArchives',
        'scoutingProfiles',
        'incomeItems',
        'sepaBatches',
        'bankTransactions',
        'quotes',
        'clientRecords',
        'supplierInvoices',
        'staff',
        'missions',
        'recruitmentOffers',
        'recruitmentCampaigns'
      ]);
    }

    function isPartnerMember(teamId) {
      return userExists()
        && userData().userRole == 'Partenaire'
        && userData().teamId == teamId;
    }

    function partnerAllowedSubcollection(subcollection) {
      return subcollection in [
        'raceEvents',
        'partnerNewsletters',
        'eventDocuments',
        'eventAccommodations'
      ];
    }

    function canReadTeam(teamId) {
      return isTeamMember(teamId) || isPartnerMember(teamId) || isSuperAdmin();
    }

    /** Annuaire équipes pour rejoindre / candidater (sans être membre). */
    function isOpenForApplications() {
      // Opt-in explicite (défaut fermé) — évite la fuite d’annuaire pour tout user connecté.
      return ('operationalSettings' in resource.data)
        && ('acceptRiderApplications' in resource.data.operationalSettings)
        && resource.data.operationalSettings.acceptRiderApplications == true;
    }

    /** Interdit d’écrire gpsWebhookKey sur le doc équipe ; suppression autorisée (migration). */
    function teamGpsSecretOk() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(['gpsWebhookKey'])
        || !('gpsWebhookKey' in request.resource.data);
    }

    match /teams/{teamId} {
      allow read: if canReadTeam(teamId)
        || (isSignedIn() && isOpenForApplications());
      // Création d’équipe : Cloud Function createTeamForUser (Admin SDK) uniquement.
      allow create: if false;
      allow update: if (isTeamManager(teamId) || isSuperAdmin())
        && subscriptionUnchanged()
        && teamGpsSecretOk();
      allow delete: if isTeamManager(teamId) || isSuperAdmin();

      // Secret GPS / config privée — managers uniquement.
      match /privateConfig/{docId} {
        allow read, write: if isTeamManager(teamId) || isSuperAdmin();
      }

      match /{subcollection}/{docId} {
        // Managers : lecture complète. Membres/coureurs : blacklist financière/RH + scope riders.
        allow read: if isTeamManager(teamId)
          || (
            isTeamMember(teamId)
            && canCoureurReadCollection(subcollection)
            && canReadTeamSubdoc(teamId, subcollection, docId)
          )
          || (isPartnerMember(teamId) && partnerAllowedSubcollection(subcollection))
          || isSuperAdmin();
        // isSelf limité aux collections profil (évite écriture arbitraire sur docId == uid).
        allow write: if isTeamManager(teamId)
          || isSuperAdmin()
          || (
            isTeamMember(teamId)
            && isSelf(docId)
            && subcollection in ['riders', 'staff', 'riderSelfDebriefs', 'peerRatings', 'convocationResponses']
          )
          || (subcollection == 'expenseReceipts'
              && isTeamMember(teamId)
              && request.resource.data.submittedByUserId == request.auth.uid);
      }

      match /expenseReceipts/{receiptId} {
        allow read: if isTeamMember(teamId) || isTeamManager(teamId) || isSuperAdmin();
        allow create: if isTeamMember(teamId)
          && request.resource.data.submittedByUserId == request.auth.uid;
        allow update: if isTeamManager(teamId)
          || isSuperAdmin()
          || (isTeamMember(teamId)
              && resource.data.submittedByUserId == request.auth.uid
              && request.resource.data.submittedByUserId == resource.data.submittedByUserId);
        allow delete: if isTeamManager(teamId)
          || isSuperAdmin()
          || (isTeamMember(teamId) && resource.data.submittedByUserId == request.auth.uid);
      }

      match /peerRatings/{ratingId} {
        allow read: if isTeamManager(teamId)
          || isSuperAdmin()
          || (isTeamMember(teamId) && resource.data.raterUserId == request.auth.uid);
        allow create: if isTeamMember(teamId)
          && request.resource.data.raterUserId == request.auth.uid;
        allow update: if isTeamManager(teamId)
          || isSuperAdmin()
          || (isTeamMember(teamId)
              && resource.data.raterUserId == request.auth.uid
              && request.resource.data.raterUserId == resource.data.raterUserId);
        allow delete: if isTeamManager(teamId) || isSuperAdmin();
      }

      match /riderSelfDebriefs/{debriefId} {
        allow read: if isTeamManager(teamId)
          || isSuperAdmin()
          || (isTeamMember(teamId) && resource.data.userId == request.auth.uid);
        allow create: if isTeamMember(teamId)
          && request.resource.data.userId == request.auth.uid;
        allow update: if isTeamManager(teamId)
          || isSuperAdmin()
          || (isTeamMember(teamId)
              && resource.data.userId == request.auth.uid
              && request.resource.data.userId == resource.data.userId);
        allow delete: if isTeamManager(teamId) || isSuperAdmin();
      }
    }

    match /teamMemberships/{membershipId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.email == authEmail() ||
        isTeamManager(resource.data.teamId) ||
        isSuperAdmin()
      );

      // Self-join PENDING (athlète/staff seulement), ou invitation manager (email_invite).
      // Jamais Manager/Partenaire en self_join — évite une élévation à l'approbation.
      allow create: if isSignedIn() && (
        (
          request.resource.data.userId == request.auth.uid
          && request.resource.data.status == 'En Attente'
          && request.resource.data.source == 'self_join'
          && request.resource.data.userRole in ['Coureur', 'Staff']
          && request.resource.data.teamId is string
          && request.resource.data.teamId.size() > 0
        )
        || (
          isTeamManager(request.resource.data.teamId)
          && request.resource.data.status == 'En Attente'
          && request.resource.data.source == 'email_invite'
          && request.resource.data.invitedBy == request.auth.uid
        )
      );

      allow update: if isSuperAdmin()
        || isTeamManager(resource.data.teamId)
        || (
          // Lier le compte à une invitation email (sans changer le statut).
          resource.data.email == authEmail()
          && resource.data.status == 'En Attente'
          && request.resource.data.status == resource.data.status
          && request.resource.data.teamId == resource.data.teamId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['userId'])
          && request.resource.data.userId == request.auth.uid
        );

      allow delete: if isTeamManager(resource.data.teamId)
        || resource.data.userId == request.auth.uid
        || isSuperAdmin();
    }

    match /permissions/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /permissionRoles/{docId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }

    match /gdprAuditLogs/{logId} {
      allow read: if isSignedIn() && (
        resource.data.performedBy == request.auth.uid ||
        resource.data.targetId == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if false;
      allow update, delete: if false;
    }

    match /scoutingRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.athleteId == request.auth.uid ||
        isTeamManager(resource.data.requesterTeamId) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn()
        && isTeamManager(request.resource.data.requesterTeamId);
      // Athlète : uniquement statut / réponse / scopes accordés.
      allow update: if isSignedIn() && (
        isTeamManager(resource.data.requesterTeamId)
        || isSuperAdmin()
        || (
          resource.data.athleteId == request.auth.uid
          && request.resource.data.athleteId == resource.data.athleteId
          && request.resource.data.requesterTeamId == resource.data.requesterTeamId
          && request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['status', 'responseDate', 'grantedScopes', 'updatedAt'])
        )
      );
      allow delete: if isTeamManager(resource.data.requesterTeamId) || isSuperAdmin();
    }

    match /userNotifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.sentByUserId == request.auth.uid
        && isTeamMember(request.resource.data.teamId)
        && exists(/databases/$(database)/documents/users/$(request.resource.data.userId))
        && get(/databases/$(database)/documents/users/$(request.resource.data.userId)).data.teamId
            == request.resource.data.teamId;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isTeamManager(resource.data.teamId) || isSuperAdmin();
    }

    match /organizations/{orgId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        request.auth.uid in resource.data.adminUserIds
      );
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.adminUserIds;
      allow update, delete: if isSignedIn() && (
        isSuperAdmin() ||
        request.auth.uid in resource.data.adminUserIds
      );
    }

    match /partnerAccesses/{accessId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        resource.data.userId == request.auth.uid ||
        isTeamManager(resource.data.teamId)
      );
      allow create, update: if isSignedIn() && (
        isSuperAdmin() ||
        isTeamManager(request.resource.data.teamId)
      );
      allow delete: if isSignedIn() && (
        isSuperAdmin() ||
        isTeamManager(resource.data.teamId)
      );
    }

    match /partnerMarketplaceProfiles/{profileId} {
      allow read: if isSignedIn() && (
        resource.data.isVisible == true ||
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        isSuperAdmin()
      );
    }

    match /teamSponsorshipNeeds/{needId} {
      allow read: if isSignedIn() && (
        resource.data.isOpen == true ||
        isTeamManager(resource.data.teamId) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn()
        && isTeamManager(request.resource.data.teamId);
      allow update, delete: if isSignedIn() && (
        isTeamManager(resource.data.teamId) ||
        isSuperAdmin()
      );
    }

    match /partnershipMatchRequests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.partnerUserId == request.auth.uid ||
        isTeamManager(resource.data.teamId) ||
        isSuperAdmin()
      );
      allow create: if isSignedIn()
        && request.resource.data.partnerUserId == request.auth.uid;
      allow update: if isSignedIn() && (
        isTeamManager(resource.data.teamId) ||
        isSuperAdmin() ||
        (resource.data.partnerUserId == request.auth.uid
          && request.resource.data.status == resource.data.status
          && request.resource.data.teamId == resource.data.teamId)
      );
      allow delete: if isSuperAdmin();
    }
  }
}
